# Copy this file to `.env.online` and fill real values locally or in a
# temporary Railway job. `.env.online` is git-ignored; do not commit secrets.

# Online check runner
RUN_ONLINE_CHECKS=false
PUBLIC_BASE_URL=<PUBLIC_BASE_URL>
ONLINE_TEST_TIMEOUT_SECONDS=10
ONLINE_REQUIRE_HEALTH_OK=true

# Optional checks. Enable only when the URL is reachable from the machine that
# runs pytest. Railway private Postgres/Redis URLs usually work only inside
# Railway's private network.
ONLINE_CHECK_DATABASE=false
ONLINE_DATABASE_SSLMODE=require
ONLINE_CHECK_REDIS=false
ONLINE_CHECK_ADMIN=false
ONLINE_INBOX_USERNAME=<ONLINE_INBOX_USERNAME>
ONLINE_INBOX_PASSWORD=<ONLINE_INBOX_PASSWORD>

# WhatsApp / Meta
WHATSAPP_TOKEN=<WHATSAPP_TOKEN>
WHATSAPP_PHONE_NUMBER_ID=<WHATSAPP_PHONE_NUMBER_ID>
GRAPH_API_VERSION=v23.0
VERIFY_TOKEN=<VERIFY_TOKEN>
META_APP_SECRET=<META_APP_SECRET>
ALLOW_UNSIGNED_WEBHOOKS=false
MAX_CONTENT_LENGTH=65536
MAX_INCOMING_TEXT_CHARS=4000
LOG_INCOMING_MESSAGES=false

# Flask / HTTP
FLASK_SECRET_KEY=<FLASK_SECRET_KEY>
FORCE_HTTPS=true

# Anthropic
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=300
ANTHROPIC_TIMEOUT_SECONDS=30

# Postgres / Redis
DATABASE_URL=<DATABASE_URL>
DATABASE_PRIVATE_URL=<DATABASE_PRIVATE_URL>
REDIS_URL=<REDIS_URL>
RATE_LIMIT_STORAGE_URL=<RATE_LIMIT_STORAGE_URL>

# Admin inbox
INBOX_ENABLED=true
INBOX_REQUIRE_ENCRYPTION=true
INBOX_ENCRYPTION_KEY=<INBOX_ENCRYPTION_KEY>
INBOX_CSRF_SECRET=<INBOX_CSRF_SECRET>
INBOX_PROOF_SECRET=<INBOX_PROOF_SECRET>
INBOX_RETENTION_DAYS=30
INBOX_AUTO_MIGRATE=true
INBOX_ADMIN_USERNAME=<INBOX_ADMIN_USERNAME>
INBOX_ADMIN_PASSWORD_HASH=<INBOX_ADMIN_PASSWORD_HASH>
INBOX_VIEWER_USERNAME=<INBOX_VIEWER_USERNAME>
INBOX_VIEWER_PASSWORD_HASH=<INBOX_VIEWER_PASSWORD_HASH>
INBOX_AUTH_MAX_FAILED_ATTEMPTS=5
INBOX_AUTH_WINDOW_SECONDS=900

# Bot behavior
BOT_DISCLOSURE=true
TEAM_NOTIFY_PHONE=<TEAM_NOTIFY_PHONE>
PRIVACY_NOTICE_URL=<PRIVACY_NOTICE_URL>
PRIVACY_RESPONSIBLE_NAME=<PRIVACY_RESPONSIBLE_NAME>
PRIVACY_RESPONSIBLE_ADDRESS=<PRIVACY_RESPONSIBLE_ADDRESS>
PRIVACY_CONTACT_EMAIL=<PRIVACY_CONTACT_EMAIL>
PRIVACY_CONTACT_PHONE=<PRIVACY_CONTACT_PHONE>
PRIVACY_NOTICE_LAST_UPDATED=2026-05-08
